# Figma API Configuration
# Get your personal access token from: https://www.figma.com/settings/tokens
FIGMA_API_TOKEN=your_figma_personal_access_token_here

# Application environment
NODE_ENV=production

# Optional: Vercel deployment environment variables
# These are automatically set by Vercel when deploying
# VERCEL_ENV=production
# VERCEL_URL=your-app.vercel.app
